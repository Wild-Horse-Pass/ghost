# =============================================================================
# Bitcoin Ghost Docker Environment Configuration
# =============================================================================
#
# SECURITY WARNING: This is an EXAMPLE file with INVALID placeholder values.
# You MUST copy this file to .env and replace ALL placeholder values before use.
#
# REQUIRED STEPS:
#   1. cp .env.example .env
#   2. Generate secure passwords: openssl rand -hex 32
#   3. Replace ALL "MUST_BE_CONFIGURED" and "GENERATE_SECURE_PASSWORD_*" values
#   4. The system will REFUSE TO START with placeholder values
#
# =============================================================================

# =============================================================================
# Version
# =============================================================================
VERSION=1.4.0

# =============================================================================
# Bitcoin Core Configuration
# =============================================================================
# SECURITY: Generate unique credentials with: openssl rand -hex 32
BITCOIN_RPC_USER=MUST_BE_CONFIGURED
BITCOIN_RPC_PASSWORD=GENERATE_SECURE_PASSWORD_WITH_openssl_rand_hex_32

# Network: signet (testing) or mainnet (production)
# For mainnet, ensure Bitcoin Core is fully synced (~600GB)
BITCOIN_NETWORK=signet

# =============================================================================
# Ghost Pool Configuration
# =============================================================================
# Public address/hostname for external miners to connect (e.g., pool.example.com)
PUBLIC_ADDRESS=

# Treasury address for pool fees (required for mainnet)
# Must be a Taproot (bc1p...) or SegWit (bc1q...) address you control
TREASURY_ADDRESS=

# Pool fee percentage (default: 1%)
TREASURY_FEE_PERCENT=1.0

# =============================================================================
# Ghost Pay L2 Configuration
# =============================================================================
VIRTUAL_BLOCK_SECS=10
EPOCH_BLOCKS=100

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Monitoring (Grafana)
# =============================================================================
# SECURITY: Generate unique credentials with: openssl rand -hex 32
GRAFANA_USER=MUST_BE_CONFIGURED
GRAFANA_PASSWORD=GENERATE_SECURE_PASSWORD_WITH_openssl_rand_hex_32
