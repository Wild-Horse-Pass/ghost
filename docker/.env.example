# Bitcoin Ghost Docker Environment Configuration
# Copy this file to .env and customize values

# =============================================================================
# Version
# =============================================================================
VERSION=1.4.0

# =============================================================================
# Bitcoin Core Configuration
# =============================================================================
BITCOIN_RPC_USER=ghostrpc
BITCOIN_RPC_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# Network: signet (testing) or mainnet (production)
# For mainnet, ensure Bitcoin Core is fully synced (~600GB)
BITCOIN_NETWORK=signet

# =============================================================================
# Ghost Pool Configuration
# =============================================================================
# Public address/hostname for external miners to connect (e.g., pool.example.com)
PUBLIC_ADDRESS=

# Treasury address for pool fees (required for mainnet)
# Must be a Taproot (bc1p...) or SegWit (bc1q...) address you control
TREASURY_ADDRESS=

# Pool fee percentage (default: 1%)
TREASURY_FEE_PERCENT=1.0

# =============================================================================
# Ghost Pay L2 Configuration
# =============================================================================
VIRTUAL_BLOCK_SECS=10
EPOCH_BLOCKS=100

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Monitoring (Grafana)
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
