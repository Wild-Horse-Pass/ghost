# Bitcoin Ghost Pool - Environment Configuration
# Copy this file to .env and edit the values

# Bitcoin Core RPC credentials
BITCOIN_RPC_USER=ghost
BITCOIN_RPC_PASSWORD=ghostpass

# Bitcoin network (signet, testnet, or mainnet)
BITCOIN_NETWORK=signet

# Your Bitcoin address for pool treasury/fees
# IMPORTANT: Change this to your own address!
TREASURY_ADDRESS=tb1qyouraddress

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
