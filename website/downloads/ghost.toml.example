# Bitcoin Ghost Pool Configuration
# Copy this file to /etc/ghost/pool.toml

[bitcoin]
# Bitcoin Core RPC connection
rpc_host = "127.0.0.1"
rpc_port = 38332          # signet: 38332, testnet: 18332, mainnet: 8332
rpc_user = "ghost"
rpc_password = "ghostpass"
network = "signet"        # signet, testnet, or mainnet

# ZMQ notifications (optional but recommended)
zmq_hashblock = "tcp://127.0.0.1:28332"

[network]
# Public address miners will connect to
public_address = "0.0.0.0"

# Stratum ports
sv2_port = 34255          # Stratum V2 (native)
sv1_port = 3333           # Stratum V1 (with SV2 translation)

# HTTP API port
http_port = 8080

[policy]
# Transaction selection policy
# - "permissive": Accept most standard transactions
# - "bitcoin_pure": Only standard Bitcoin transactions
# - "full_open": Accept all valid transactions
profile = "permissive"

[storage]
# Data directory for pool state
data_dir = "/var/lib/ghost"

# Archive mode keeps full share history (uses more disk)
archive_mode = false

[pool]
# Treasury address receives pool fees
# IMPORTANT: Change this to your own address!
treasury_address = "tb1qyouraddress"

# Pool fee percentage (1.0 = 1%)
fee_percent = 1.0

# Minimum payout in satoshis (100000 = 0.001 BTC)
min_payout_sats = 100000

# Maximum miners per pool instance
max_miners = 1000

[coordinator]
# Register with coordinator for smart routing (optional)
enabled = true
url = "https://pool.bitcoinghost.org"
region = "north_america"  # north_america, south_america, europe, asia, oceania, africa
