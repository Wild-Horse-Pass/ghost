#!/usr/bin/env bash
# ghost-mempool — install / uninstall / status for the per-node mempool stack
#
# Optional add-on for Ghost node operators who want a local mempool.space
# instance pointed at THEIR ghostd (rather than relying on a public one).
# Stack: mempool-backend + electrs + mempool-frontend, all in Docker.
#
# Usage:
#   sudo ghost-mempool install      — pre-flight + bring up
#   sudo ghost-mempool uninstall    — bring down + remove
#   sudo ghost-mempool status       — print state
#
# Resource floor: 4 GB free RAM, 50 GB free disk on the install dir.
# Below the floor the installer refuses — won't break a tight node.

set -euo pipefail

# ─── config ───────────────────────────────────────────────────────────────

readonly INSTALL_DIR="/opt/ghost/mempool-stack"
readonly MARKER_FILE="/etc/ghost/mempool-stack.enabled"
readonly SERVICE_UNIT="/etc/systemd/system/ghost-mempool.service"
readonly DEFAULT_PORT=8999
readonly MIN_RAM_MB=$((4 * 1024))   # 4 GB
readonly MIN_DISK_MB=$((50 * 1024)) # 50 GB
readonly GHOST_CONF_PATHS=(
  "/etc/bitcoin/bitcoin.conf"
  "/home/ghost/.ghost/ghost.conf"
  "/etc/ghost/ghost.conf"
)

# Mempool.space upstream — pinned to a known-good tag rather than `latest` so
# operators don't get surprised by a breaking change between installs.
readonly MEMPOOL_BACKEND_IMAGE="mempool/backend:v3.0.0"
readonly MEMPOOL_FRONTEND_IMAGE="mempool/frontend:v3.0.0"
readonly ELECTRS_IMAGE="getumbrel/electrs:v0.10.6"

# ─── helpers ──────────────────────────────────────────────────────────────

log() { printf '\033[1;36m%s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m%s\033[0m\n' "$*" >&2; }
fail() { printf '\033[1;31m%s\033[0m\n' "$*" >&2; exit 1; }

require_root() {
  if [[ $EUID -ne 0 ]]; then
    fail "Run with sudo (this script writes to /opt, /etc, and uses Docker)."
  fi
}

# ─── pre-flight ───────────────────────────────────────────────────────────

# Check for Docker — install if missing? No, fail fast with a clear message.
# Operator should opt into Docker explicitly, not have it sneak onto their box.
check_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    fail "Docker not installed. Install with:
    curl -fsSL https://get.docker.com | sudo sh
  Then re-run: sudo ghost-mempool install"
  fi
  if ! docker compose version >/dev/null 2>&1; then
    fail "Docker Compose v2 not available. Update Docker:
    sudo apt-get install --only-upgrade docker-ce docker-ce-cli docker-compose-plugin"
  fi
}

# RAM in MB. Reads from /proc/meminfo (matches what ghost-pool's capacity
# module uses — see bins/ghost-pool/src/capacity.rs).
free_ram_mb() {
  local kb
  kb=$(awk '/^MemAvailable:/ {print $2; exit}' /proc/meminfo 2>/dev/null || echo 0)
  echo $((kb / 1024))
}

# Free disk on the install partition, in MB.
free_disk_mb() {
  df -BM --output=avail "$1" 2>/dev/null | awk 'NR==2 {gsub(/M/,""); print}' || echo 0
}

preflight() {
  log "Pre-flight checks..."

  local ram disk
  ram=$(free_ram_mb)
  disk=$(free_disk_mb "$(dirname "$INSTALL_DIR")")

  log "  RAM available:  ${ram} MB (need ≥ ${MIN_RAM_MB} MB)"
  log "  Disk available: ${disk} MB (need ≥ ${MIN_DISK_MB} MB)"

  if (( ram < MIN_RAM_MB )); then
    fail "Not enough free RAM. Skipping install — your existing services need the headroom."
  fi
  if (( disk < MIN_DISK_MB )); then
    fail "Not enough free disk on $(dirname "$INSTALL_DIR"). electrs needs ~30 GB to index, plus working room."
  fi

  check_docker
  log "  Docker:         present"
}

# ─── locate ghostd RPC creds ──────────────────────────────────────────────

read_rpc_creds() {
  local f user pass port=8332
  for f in "${GHOST_CONF_PATHS[@]}"; do
    if [[ -r $f ]]; then
      user=$(awk -F= '/^rpcuser=/ {print $2; exit}' "$f")
      pass=$(awk -F= '/^rpcpassword=/ {print $2; exit}' "$f")
      port=$(awk -F= '/^rpcport=/ {print $2; exit}' "$f")
      port=${port:-8332}
      if [[ -n ${user:-} && -n ${pass:-} ]]; then
        printf '%s|%s|%s\n' "$user" "$pass" "$port"
        return 0
      fi
    fi
  done
  fail "Could not find rpcuser/rpcpassword in any of: ${GHOST_CONF_PATHS[*]}"
}

# ─── compose generation ───────────────────────────────────────────────────

write_compose() {
  local rpc_user=$1 rpc_pass=$2 rpc_port=$3 port=$4
  mkdir -p "$INSTALL_DIR"
  cat > "$INSTALL_DIR/docker-compose.yml" <<EOF
# Generated by ghost-mempool — do not hand-edit.
# Rerun: sudo ghost-mempool install
services:
  electrs:
    image: ${ELECTRS_IMAGE}
    restart: unless-stopped
    network_mode: host
    environment:
      - DAEMON_RPC_ADDR=127.0.0.1:${rpc_port}
      - DAEMON_RPC_USER=${rpc_user}
      - DAEMON_RPC_PASS=${rpc_pass}
      - ELECTRS_PORT=50001
      - ELECTRS_HTTP_PORT=8094
    volumes:
      - electrs-data:/data

  mempool-backend:
    image: ${MEMPOOL_BACKEND_IMAGE}
    restart: unless-stopped
    network_mode: host
    depends_on: [electrs]
    environment:
      - MEMPOOL_BACKEND=electrum
      - ELECTRUM_HOST=127.0.0.1
      - ELECTRUM_PORT=50001
      - ELECTRUM_TLS_ENABLED=false
      - CORE_RPC_HOST=127.0.0.1
      - CORE_RPC_PORT=${rpc_port}
      - CORE_RPC_USERNAME=${rpc_user}
      - CORE_RPC_PASSWORD=${rpc_pass}

  mempool-frontend:
    image: ${MEMPOOL_FRONTEND_IMAGE}
    restart: unless-stopped
    depends_on: [mempool-backend]
    ports:
      - "127.0.0.1:${port}:8080"
    environment:
      - FRONTEND_HTTP_PORT=8080
      - BACKEND_MAINNET_HTTP_HOST=127.0.0.1

volumes:
  electrs-data:
EOF
  chmod 600 "$INSTALL_DIR/docker-compose.yml"  # contains RPC password
}

# ─── systemd unit ─────────────────────────────────────────────────────────

write_systemd_unit() {
  cat > "$SERVICE_UNIT" <<EOF
[Unit]
Description=Ghost mempool stack (mempool.space + electrs)
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=${INSTALL_DIR}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
EOF
  systemctl daemon-reload
}

# ─── subcommands ──────────────────────────────────────────────────────────

cmd_install() {
  require_root
  preflight

  if [[ -f $MARKER_FILE ]]; then
    warn "Marker file already present at $MARKER_FILE."
    warn "Running install will reuse the existing port and refresh the stack."
  fi

  local creds rpc_user rpc_pass rpc_port port
  creds=$(read_rpc_creds)
  rpc_user=${creds%%|*}
  rpc_pass=${creds#*|}; rpc_pass=${rpc_pass%%|*}
  rpc_port=${creds##*|}
  port=${MEMPOOL_PORT:-$DEFAULT_PORT}

  log "Generating docker-compose.yml at $INSTALL_DIR..."
  write_compose "$rpc_user" "$rpc_pass" "$rpc_port" "$port"

  log "Pulling images (this can take a few minutes the first time)..."
  (cd "$INSTALL_DIR" && docker compose pull)

  log "Starting stack..."
  (cd "$INSTALL_DIR" && docker compose up -d)

  log "Writing systemd unit ($SERVICE_UNIT)..."
  write_systemd_unit
  systemctl enable --now ghost-mempool.service

  mkdir -p "$(dirname "$MARKER_FILE")"
  echo "$port" > "$MARKER_FILE"

  log ""
  log "✓ Installed."
  log "  Frontend:    http://localhost:${port}/"
  log "  Marker:      $MARKER_FILE (port=${port})"
  log "  electrs may take 30-60 minutes to finish indexing on first run."
  log "  The dashboard /mempool page auto-detects when it's live."
}

cmd_uninstall() {
  require_root
  log "Stopping stack..."
  systemctl disable --now ghost-mempool.service 2>/dev/null || true
  if [[ -d $INSTALL_DIR ]]; then
    (cd "$INSTALL_DIR" && docker compose down -v 2>/dev/null) || true
  fi
  rm -f "$SERVICE_UNIT"
  systemctl daemon-reload
  rm -f "$MARKER_FILE"
  log "Removing $INSTALL_DIR..."
  rm -rf "$INSTALL_DIR"
  log "✓ Uninstalled."
  log "  electrs data volume removed (-v on docker compose down)."
}

cmd_status() {
  if [[ -f $MARKER_FILE ]]; then
    local port
    port=$(cat "$MARKER_FILE" 2>/dev/null || echo "?")
    echo "Marker:    $MARKER_FILE (port=$port)"
  else
    echo "Marker:    absent (not installed)"
  fi
  echo -n "Service:   "
  systemctl is-active ghost-mempool.service 2>/dev/null || echo "inactive"
  echo -n "Compose:   "
  if [[ -d $INSTALL_DIR ]]; then
    (cd "$INSTALL_DIR" && docker compose ps --format 'table {{.Service}}\t{{.Status}}' 2>/dev/null) || echo "no compose project"
  else
    echo "not installed"
  fi
}

# ─── entry ────────────────────────────────────────────────────────────────

cmd=${1:-}
case "$cmd" in
  install)   cmd_install ;;
  uninstall) cmd_uninstall ;;
  status)    cmd_status ;;
  ""|-h|--help|help)
    cat <<EOF
ghost-mempool — per-node mempool.space stack (opt-in)

Subcommands:
  install     pre-flight + bring up the stack
  uninstall   stop and remove everything (including the indexed data)
  status      show install / service / container state

Environment:
  MEMPOOL_PORT    override the frontend port (default ${DEFAULT_PORT})

Resource requirements: ≥${MIN_RAM_MB} MB free RAM, ≥${MIN_DISK_MB} MB free disk.
Compose files live at: ${INSTALL_DIR}
Marker file:           ${MARKER_FILE}
EOF
    ;;
  *) fail "Unknown subcommand: $cmd. Try 'ghost-mempool help'." ;;
esac
