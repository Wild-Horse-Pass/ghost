# =============================================================================
# Bitcoin Ghost - Mainnet Environment Variables
# =============================================================================
#
# Copy this file to mainnet.env and fill in your values.
# NEVER commit mainnet.env to version control!
#
# Usage:
#   source mainnet.env && ghost-pool --config mainnet.toml
#   # or
#   docker run --env-file mainnet.env ghost-pool
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Bitcoin Core RPC
# -----------------------------------------------------------------------------

# Bitcoin Core RPC password (from bitcoin.conf rpcpassword)
BITCOIN_RPC_PASSWORD=CHANGE_ME_SECURE_RPC_PASSWORD

# Bitcoin Core RPC username (optional, defaults to ghostrpc)
# BITCOIN_RPC_USER=ghostrpc

# -----------------------------------------------------------------------------
# REQUIRED - Network Configuration
# -----------------------------------------------------------------------------

# Public IP address or hostname for miner connections
# Must be reachable from the internet for public pools
PUBLIC_ADDRESS=your.pool.hostname.com

# -----------------------------------------------------------------------------
# REQUIRED - Pool Economics
# -----------------------------------------------------------------------------

# Treasury address for pool fees (use P2TR bc1p... for best privacy)
# SECURITY: Generate a new address you control!
TREASURY_ADDRESS=bc1pYOUR_TREASURY_ADDRESS_HERE

# -----------------------------------------------------------------------------
# REQUIRED - Security Keys
# -----------------------------------------------------------------------------

# Message signing key (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
SIGNING_KEY=GENERATE_WITH_openssl_rand_hex_32

# Internal API authentication secret (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=GENERATE_WITH_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# OPTIONAL - Private Mining
# -----------------------------------------------------------------------------

# Password for private mining modes (min 8 chars)
# Required only when mining_mode = private_pool or private_solo
# PRIVATE_MINING_PASSWORD=your_secure_password

# -----------------------------------------------------------------------------
# OPTIONAL - Monitoring
# -----------------------------------------------------------------------------

# Log level: trace, debug, info, warn, error
# LOG_LEVEL=info

# Grafana credentials (if using monitoring stack)
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin

# =============================================================================
# Quick Setup Checklist
# =============================================================================
#
# 1. [ ] Generate node key:
#        ghost-cli key generate --output /etc/ghost/node.key
#
# 2. [ ] Generate signing key:
#        export SIGNING_KEY=$(openssl rand -hex 32)
#
# 3. [ ] Generate API secret:
#        export INTERNAL_API_SECRET=$(openssl rand -hex 32)
#
# 4. [ ] Set your public IP/hostname:
#        export PUBLIC_ADDRESS=your.pool.hostname.com
#
# 5. [ ] Generate treasury address (in your Bitcoin wallet)
#        export TREASURY_ADDRESS=bc1p...
#
# 6. [ ] Configure Bitcoin Core RPC password:
#        export BITCOIN_RPC_PASSWORD=your_rpc_password
#
# 7. [ ] Open firewall ports:
#        3333 (SV1), 34255 (SV2), 8080 (API), 8555-8562 (P2P mesh)
#
# 8. [ ] Start the pool:
#        source mainnet.env && ghost-pool --config mainnet.toml
#
# =============================================================================
